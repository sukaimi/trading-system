# Executor mode: paper | alpaca | live | ibkr
#   paper   — simulated fills at real market prices (default)
#   alpaca  — Alpaca paper/live for ALL assets (set ALPACA_BASE_URL)
#   live    — Routes: crypto→Coinbase, stocks/ETFs→Alpaca live
#   ibkr    — Interactive Brokers (legacy)
EXECUTOR_MODE=alpaca

# Dashboard
DASHBOARD_PORT=8080

# Interactive Brokers (when EXECUTOR_MODE=ibkr)
IBKR_HOST=127.0.0.1
IBKR_PAPER_PORT=7497
IBKR_LIVE_PORT=7496
IBKR_CLIENT_ID=1
IBKR_PAPER_MODE=true

# Alpaca (when EXECUTOR_MODE=alpaca or live)
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# Coinbase Advanced Trade (when EXECUTOR_MODE=live, for crypto)
COINBASE_API_KEY=organizations/{org_id}/apiKeys/{key_id}
COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----

# Finnhub (Earnings transcripts, alternative data)
FINNHUB_API_KEY=your-finnhub-api-key

# DeepSeek (Tier 1 — Workhorse)
DEEPSEEK_API_KEY=your-deepseek-api-key

# Kimi / Moonshot (Tier 2 — Analyst)
KIMI_API_KEY=your-kimi-api-key

# Anthropic (Tier 3 — Commander)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini (Fallback)
GOOGLE_API_KEY=your-google-api-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Alpha Vantage
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# CryptoCompare
CRYPTOCOMPARE_API_KEY=your-cryptocompare-key

# Google Analytics 4 (optional — each tenant needs their own GA property)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your-ga4-api-secret
